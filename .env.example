# PostgreSQL
VERHUB_POSTGRES_DB=verhub
VERHUB_POSTGRES_USER=verhub
VERHUB_POSTGRES_PASSWORD=change-this-strong-db-password

# Verhub backend
JWT_SECRET=change-this-very-strong-jwt-secret
JWT_EXPIRES_IN=2h
API_KEY_SALT=change-this-unique-api-key-salt
ADMIN_PASSWORD=

# Frontend build-time API base URL
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Frontend gateway exposed ports (nginx)
VERHUB_HTTP_PORT=80
VERHUB_HTTPS_PORT=443
