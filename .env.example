# -----------------------------
# Docker / Docker Compose env
# Copy to .env before deploy.
# -----------------------------

# PostgreSQL
POSTGRES_DB=verhub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-strong-db-password

# Backend
JWT_SECRET=change-this-strong-jwt-secret
JWT_EXPIRES_IN=2h
API_KEY_SALT=change-this-strong-api-key-salt

# Leave empty to auto-generate bootstrap admin password on first startup.
# If empty, backend writes credentials to BOOTSTRAP_SECRET_DIR and prints
# username/password in backend container logs once.
ADMIN_PASSWORD=

# Bootstrap credential output path inside backend container.
BOOTSTRAP_SECRET_DIR=/bootstrap

# CORS and frontend API base
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1