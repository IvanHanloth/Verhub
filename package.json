{
  "name": "verhub",
  "private": true,
  "version": "0.1.01",
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "docs:dev": "pnpm --filter verhub-docs docs:dev",
    "docs:build": "pnpm --filter verhub-docs docs:build",
    "docs:preview": "pnpm --filter verhub-docs docs:preview",
    "admin:reset": "pnpm --filter @workspace/backend run admin:reset",
    "lint-staged": "lint-staged",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.18",
    "typescript": "5.9.3"
  },
  "lint-staged": {
    "packages/backend/**/*.{js,cjs,mjs,ts,tsx,jsx}": [
      "pnpm --filter @workspace/backend exec eslint --fix --max-warnings=0",
      "pnpm --filter @workspace/backend exec prettier --write"
    ],
    "web/**/*.{js,cjs,mjs,ts,tsx,jsx}": [
      "pnpm --filter web exec eslint --fix --max-warnings=0",
      "pnpm --filter web exec prettier --write"
    ],
    "packages/ui/**/*.{js,cjs,mjs,ts,tsx,jsx}": [
      "pnpm --filter @workspace/ui exec eslint --fix --max-warnings=0",
      "pnpm --filter @workspace/ui exec prettier --write"
    ],
    "*.{json,md,css,scss,yaml,yml}": [
      "prettier --write"
    ]
  }
}
