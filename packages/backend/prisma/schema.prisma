generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  GUEST
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum ClientPlatform {
  IOS
  ANDROID
  WINDOWS
  MAC
  WEB
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  apiKeys      ApiKey[]
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  keyHash     String   @unique
  previousKeyHash      String?
  previousKeyExpiresAt DateTime?
  scopes      String[] @default([])
  allProjects Boolean  @default(true)
  projectIds  String[] @default([])
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  revokedAt   DateTime?
  createdById String?

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([isActive, expiresAt])
}

model Project {
  id            String         @id @default(cuid())
  projectKey    String         @unique
  name          String
  repoUrl       String?
  description   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  versions      Version[]
  announcements Announcement[]
  feedbacks     Feedback[]
  logs          Log[]
  actions       Action[]
}

model Action {
  id          String         @id @default(cuid())
  projectId   String
  name        String
  description String
  customData  Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  records     ActionRecord[]

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model ActionRecord {
  id         String   @id @default(cuid())
  actionId   String
  http       Json?
  customData Json?
  createdAt  DateTime @default(now())

  action Action @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@index([actionId, createdAt])
}

model Version {
  id          String         @id @default(cuid())
  projectId   String
  version     String
  title       String?
  content     String?
  downloadUrl String
  forced      Boolean        @default(false)
  platform    ClientPlatform?
  customData  Json?
  createdAt   DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  projectId String
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model Feedback {
  id         String   @id @default(cuid())
  projectId  String
  userId     String?
  rating     Int?
  content    String
  platform   ClientPlatform?
  customData Json?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
}

model Log {
  id         String   @id @default(cuid())
  projectId  String
  level      LogLevel
  content    String
  deviceInfo Json?
  customData Json?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([level, createdAt])
}
