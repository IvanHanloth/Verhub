{
  "name": "verhub-sdk",
  "version": "0.2.3",
  "description": "Verhub 版本与发布管理平台的官方 TypeScript / JavaScript SDK",
  "license": "Apache-2.0",
  "author": "IvanHanloth <ivan@hanloth.com>",
  "homepage": "https://ivanhanloth.github.io/Verhub/reference/sdk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanHanloth/verhub.git",
    "directory": "sdk/typescript"
  },
  "bugs": "https://github.com/IvanHanloth/verhub/issues",
  "keywords": [
    "verhub",
    "version",
    "release",
    "changelog",
    "update",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
